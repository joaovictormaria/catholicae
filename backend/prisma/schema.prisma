generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Church {
  id        Int                                    @id @default(autoincrement())
  name      String
  latitude  Float
  longitude Float
  address   String?
  city      String?
  state     String?
  phone     String?
  source    String
  location  Unsupported("geography(Point, 4326)")?
  createdAt DateTime                               @default(now())

  @@index([latitude, longitude])
  @@index([location], type: Gist)
}
